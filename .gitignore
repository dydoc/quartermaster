#
# workspace.json is generated by Structurizr when you adjust diagram layouts in the UI.
# COMMIT IT: it holds the manual element positions. Without it, every restart
# falls back to autolayout and all manual positioning is lost.
# workspace.json  ← do NOT ignore this file

# Exported files are generated artefacts — do not commit them.
# Regenerate with `make export` whenever needed.
design/exported/

# Playwright downloads Chromium on first use inside the container.
# No need to persist it — it is re-downloaded automatically.
.playwright/

# Structurizr temporary files
*.bak
.structurizr

